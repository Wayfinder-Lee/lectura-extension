{
  "manifest_version": 3,
  "name": "LECTURA Vocabulary Builder",
  "version": "1.1.1",
  "description": "Select words on any webpage for instant offline dictionary lookup, text highlighting, and flashcard review. ECDICT + LLM powered.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "unlimitedStorage",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open LECTURA"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/link-shield.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-side-panel": {
      "suggested_key": {
        "default": "Ctrl+Shift+L"
      },
      "description": "Toggle LECTURA side panel"
    }
  },
  "options_ui": {
    "page": "settings/settings.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["content/*.js", "content/*.css", "content/reading/*.js", "content/reading/*.css", "shared/*.js", "shared/*.json", "sidepanel/*.js", "learn/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
